{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ebibibi/nestedhyper-v/schema/l2.schema.json",
  "title": "Nested Hyper-V L2 environment definition",
  "type": "object",
  "additionalProperties": false,
  "minProperties": 1,
  "properties": {
    "defaults": { "$ref": "#/$defs/vmCommon" },
    "domain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fqdn"],
      "properties": {
        "fqdn": { "type": "string", "pattern": "^[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$" },
        "netbios": { "type": "string", "maxLength": 15 },
        "dsrm_password": { "type": "string" },
        "controllers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "ip"],
            "properties": {
              "name": { "type": "string" },
              "ip": { "$ref": "#/$defs/ipv4" },
              "cpu": { "type": "integer", "minimum": 1 },
              "memory_gb": { "type": "number", "minimum": 1 },
              "os": { "type": "string" }
            }
          }
        }
      }
    },
    "groups": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "count", "ip_from"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "name_prefix": { "type": "string" },
          "count": { "type": "integer", "minimum": 1 },
          "index_start": { "type": "integer", "minimum": 0, "default": 1 },
          "index_width": { "type": "integer", "minimum": 1, "default": 2 },
          "ip_from": { "$ref": "#/$defs/ipv4" },
          "cpu": { "type": "integer", "minimum": 1 },
          "memory_gb": { "type": "number", "minimum": 1 },
          "os": { "type": "string" },
          "generation": { "type": "integer", "enum": [1, 2] },
          "domain_join": { "type": ["string", "boolean"] },
          "disk_gb": { "type": "number", "minimum": 20 },
          "language": { "type": "string" },
          "data_disks": {
            "type": "object",
            "additionalProperties": false,
            "required": ["count", "size_gb"],
            "properties": {
              "count": { "type": "integer", "minimum": 1 },
              "size_gb": { "type": "number", "minimum": 1 }
            }
          },
          "roles": { "type": "array", "items": { "type": "string" } },
          "features": { "type": "array", "items": { "type": "string" } },
          "cluster": { "$ref": "#/$defs/groupCluster" },
          "overrides": {
            "type": "object",
            "additionalProperties": { "$ref": "#/$defs/vmOverride" }
          }
        }
      }
    },
    "vms": {
      "type": "array",
      "items": { "$ref": "#/$defs/vmExplicit" }
    },
    "clusters": {
      "type": "array",
      "items": { "$ref": "#/$defs/clusterExplicit" }
    }
  },
  "$defs": {
    "ipv4": { "type": "string", "pattern": "^\\d{1,3}(\\.\\d{1,3}){3}$" },
    "vmCommon": {
      "type": "object",
      "properties": {
        "cpu": { "type": "integer", "minimum": 1 },
        "memory_gb": { "type": "number", "minimum": 1 },
        "os": { "type": "string" },
        "generation": { "type": "integer", "enum": [1, 2] },
        "domain_join": { "type": ["string", "boolean"] },
        "disk_gb": { "type": "number", "minimum": 20 },
        "language": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } }
      }
    },
    "disk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "size_gb"],
      "properties": {
        "role": { "type": "string", "enum": ["os", "data"] },
        "size_gb": { "type": "number", "minimum": 1 }
      }
    },
    "nic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["switch"],
      "properties": {
        "switch": { "type": "string" },
        "ip": { "$ref": "#/$defs/ipv4" },
        "gw": { "$ref": "#/$defs/ipv4" },
        "dns": { "$ref": "#/$defs/ipv4" }
      }
    },
    "provision": {
      "type": "object",
      "properties": {
        "domain_join": { "type": ["string", "boolean"] },
        "roles": { "type": "array", "items": { "type": "string" } },
        "post": { "type": "array" }
      }
    },
    "vmOverride": {
      "type": "object",
      "properties": {
        "cpu": { "type": "integer", "minimum": 1 },
        "memory_gb": { "type": "number", "minimum": 1 },
        "os": { "type": "string" },
        "generation": { "type": "integer", "enum": [1, 2] },
        "domain_join": { "type": ["string", "boolean"] },
        "disk_gb": { "type": "number", "minimum": 20 },
        "language": { "type": "string" },
        "disks": { "type": "array", "items": { "$ref": "#/$defs/disk" } },
        "nics": { "type": "array", "items": { "$ref": "#/$defs/nic" } },
        "provision": { "$ref": "#/$defs/provision" },
        "features": { "type": "array", "items": { "type": "string" } }
      }
    },
    "vmExplicit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "cpu": { "type": "integer", "minimum": 1 },
        "memory_gb": { "type": "number", "minimum": 1 },
        "os": { "type": "string" },
        "generation": { "type": "integer", "enum": [1, 2] },
        "domain_join": { "type": ["string", "boolean"] },
        "language": { "type": "string" },
        "disks": { "type": "array", "items": { "$ref": "#/$defs/disk" } },
        "nics": { "type": "array", "items": { "$ref": "#/$defs/nic" } },
        "provision": { "$ref": "#/$defs/provision" },
        "features": { "type": "array", "items": { "type": "string" } }
      }
    },
    "groupCluster": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "ip"],
      "properties": {
        "name": { "type": "string" },
        "ip": { "$ref": "#/$defs/ipv4" },
        "s2d": { "type": "boolean", "default": false },
        "witness": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": { "type": "string", "enum": ["fileshare", "disk", "cloud"] },
            "host": { "type": "string" },
            "path": { "type": "string" }
          }
        },
        "role": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": { "type": "string" },
            "volume_gb": { "type": "number", "minimum": 1 }
          }
        }
      }
    },
    "clusterExplicit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "ip", "nodes"],
      "properties": {
        "name": { "type": "string" },
        "ip": { "$ref": "#/$defs/ipv4" },
        "nodes": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "storage": {
          "type": "object",
          "properties": {
            "s2d": {
              "type": "object",
              "properties": { "enabled": { "type": "boolean" } }
            }
          }
        },
        "witness": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["fileshare", "disk", "cloud"] },
            "host": { "type": "string" },
            "path": { "type": "string" }
          }
        },
        "roles": { "type": "array" }
      }
    }
  }
}
